# CrewUp / remote development environment variables
# Copy this file to .env on the remote server and fill values manually.
# Never commit a real .env file.

# Supabase frontend anon config only. Do NOT use service_role in frontend config.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Hermes Obsidian integration. On the remote server this path is created by scripts/bootstrap_remote_dev.sh.
OBSIDIAN_VAULT_PATH=/home/ubuntu/crewup-work/Obsidian_Vault

# Optional deployment/CLI tokens. Keep these secret.
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
# GITHUB_TOKEN=

# Optional model/provider credentials if you use API-key based providers through Hermes.
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=
